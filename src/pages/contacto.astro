---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, brandFull } from '../config/site';
import { buildWhatsAppLink } from '../lib/whatsapp';

const wspGeneral = buildWhatsAppLink(
  `Hola ${brandFull}, quiero consultar por una propiedad en ${SITE.city}.`,
);
const wspVender = buildWhatsAppLink(
  `Hola ${brandFull}, quiero publicar mi propiedad en ${SITE.city} para vender o alquilar.`,
);
---

<BaseLayout title={`Contacto | ${SITE.name}`} description={`Contactá a ${SITE.name} en Paraná por WhatsApp o formulario.`}>
  <section class="bg-brand-gray-900 px-5 py-12 text-white">
    <div class="mx-auto max-w-6xl">
      <h1 class="font-display text-3xl font-bold">Contacto</h1>
      <p class="mt-2 text-brand-gray-100">Coordinamos visitas y resolvemos tus consultas sobre propiedades en Paraná.</p>
    </div>
  </section>

  <div class="mx-auto max-w-2xl px-5 py-12">
    <div class="mb-8 rounded-2xl border border-brand-gray-200 bg-brand-gray-50 p-5 text-sm text-brand-gray-700">
      <p class="font-semibold text-brand-gray-900">Oficina</p>
      <p class="mt-1">{SITE.address}</p>
      <p class="mt-2">
        Tel:{' '}
        <a href={`tel:+54${SITE.phone}`} class="font-medium text-brand-gray-900 no-underline hover:underline">
          {SITE.phoneDisplay}
        </a>
      </p>
    </div>

    <div class="mb-8 flex flex-wrap gap-3">
      <a
        href={wspGeneral}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex rounded-lg bg-brand-yellow px-5 py-2.5 text-sm font-bold text-brand-gray-900 no-underline hover:bg-brand-yellow-dark"
      >
        WhatsApp — Consulta general
      </a>
      <a
        href={wspVender}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex rounded-lg border border-brand-gray-200 bg-white px-5 py-2.5 text-sm font-semibold text-brand-gray-900 no-underline hover:bg-brand-yellow-soft"
      >
        Quiero publicar mi propiedad
      </a>
    </div>

    <form id="contact-form" class="space-y-4 rounded-2xl border border-brand-gray-200 bg-white p-6 shadow-sm" novalidate>
      <input type="hidden" name="website" tabindex="-1" autocomplete="off" />
      <input type="hidden" id="property-slug" name="propertySlug" />

      <div>
        <label for="nombre" class="mb-1 block text-sm font-medium text-brand-gray-700">Nombre</label>
        <input id="nombre" name="nombre" type="text" required class="w-full rounded-lg border border-brand-gray-200 px-3 py-2 focus:ring-2 focus:ring-brand-yellow" />
      </div>
      <div>
        <label for="email" class="mb-1 block text-sm font-medium text-brand-gray-700">Email</label>
        <input id="email" name="email" type="email" required class="w-full rounded-lg border border-brand-gray-200 px-3 py-2 focus:ring-2 focus:ring-brand-yellow" />
      </div>
      <div>
        <label for="telefono" class="mb-1 block text-sm font-medium text-brand-gray-700">Teléfono (opcional)</label>
        <input id="telefono" name="telefono" type="tel" class="w-full rounded-lg border border-brand-gray-200 px-3 py-2 focus:ring-2 focus:ring-brand-yellow" />
      </div>
      <div>
        <label for="mensaje" class="mb-1 block text-sm font-medium text-brand-gray-700">Mensaje</label>
        <textarea id="mensaje" name="mensaje" required rows="5" class="w-full rounded-lg border border-brand-gray-200 px-3 py-2 focus:ring-2 focus:ring-brand-yellow" placeholder="Contanos qué tipo de propiedad buscás o querés publicar..."></textarea>
      </div>
      <button type="submit" class="rounded-lg bg-brand-gray-900 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-gray-700">
        Enviar por WhatsApp
      </button>
    </form>

    <p id="form-message" class="mt-4 hidden rounded-lg p-3 text-sm" role="status"></p>
    <p class="mt-4 text-xs text-brand-gray-500">
      El formulario abre WhatsApp con tu mensaje. También podés escribirnos a{' '}
      <a href={`mailto:${SITE.email}`} class="text-brand-gray-900 underline-offset-2 hover:underline">
        {SITE.email}
      </a>
      . Respondemos consultas sobre venta y alquiler en {SITE.city}.
    </p>
    <p class="mt-3 text-sm text-brand-gray-700">
      <span class="font-medium text-brand-gray-900">Seguinos:</span>{' '}
      <a
        href={SITE.instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-brand-gray-900 underline-offset-2 hover:underline"
      >
        Instagram
      </a>
      {' · '}
      <a
        href={SITE.facebookUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-brand-gray-900 underline-offset-2 hover:underline"
      >
        Facebook
      </a>
    </p>
  </div>
</BaseLayout>

<script define:vars={{ whatsappNumber: SITE.whatsappNumber, brandName: brandFull }}>
  const form = document.querySelector('#contact-form');
  const message = document.querySelector('#form-message');
  const propertySlugInput = document.querySelector('#property-slug');
  const mensajeInput = document.querySelector('#mensaje');

  const params = new URLSearchParams(window.location.search);
  const propertySlug = params.get('property');
  const propertyTitle = params.get('title');

  if (propertySlugInput instanceof HTMLInputElement && propertySlug) {
    propertySlugInput.value = propertySlug;
  }
  if (mensajeInput instanceof HTMLTextAreaElement && propertyTitle && !mensajeInput.value.trim()) {
    mensajeInput.value = `Hola, me interesa la propiedad: ${propertyTitle}. Quisiera coordinar una visita o recibir más información.`;
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const data = new FormData(form);
    const nombre = (data.get('nombre') || '').toString().trim();
    const email = (data.get('email') || '').toString().trim();
    const mensaje = (data.get('mensaje') || '').toString().trim();
    const website = (data.get('website') || '').toString().trim();

    if (!nombre || !email || !mensaje || website) {
      showMessage('Completá los campos obligatorios.', 'error');
      return;
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showMessage('Ingresá un email válido.', 'error');
      return;
    }

    const telefono = (data.get('telefono') || '').toString().trim();
    const propertySlug = (data.get('propertySlug') || '').toString().trim();
    const lines = [
      `Hola ${brandName},`,
      '',
      `Nombre: ${nombre}`,
      `Email: ${email}`,
    ];
    if (telefono) lines.push(`Teléfono: ${telefono}`);
    if (propertySlug) lines.push(`Propiedad: ${propertySlug}`);
    lines.push('', mensaje);
    const wspUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(lines.join('\n'))}`;
    window.open(wspUrl, '_blank', 'noopener,noreferrer');
    showMessage(
      'Se abrió WhatsApp con tu consulta. Si no se abrió, usá los botones de arriba o escribinos por email.',
      'success',
    );
    form.reset();
  });

  function showMessage(text: string, type: 'error' | 'success') {
    if (!message) return;
    message.textContent = text;
    message.classList.remove('hidden', 'bg-red-50', 'text-red-700', 'bg-emerald-50', 'text-emerald-800');
    message.classList.add(type === 'error' ? 'bg-red-50' : 'bg-emerald-50', type === 'error' ? 'text-red-700' : 'text-emerald-800');
  }
</script>
