---
import BaseLayout from '../layouts/BaseLayout.astro';
import PropertyCard from '../components/PropertyCard.astro';
import PropertyHeroSlider from '../components/PropertyHeroSlider.astro';
import ButtonLink from '../components/ui/ButtonLink.astro';
import { SITE } from '../config/site';
import { getApiUrl } from '../lib/api';
import { getWorkerEnv } from '../lib/cf-env';
import { loadFeaturedProperties, loadHeroSliderProperties } from '../lib/catalog';

const apiUrl = getApiUrl(getWorkerEnv());
const heroSlides = await loadHeroSliderProperties(apiUrl);
const featured = await loadFeaturedProperties(apiUrl);
const featuredGrid = featured.slice(0, 4);

const highlights = [
  {
    title: 'Asesoramiento personalizado',
    text: 'Entendemos tu búsqueda y te acompañamos en cada decisión.',
  },
  {
    title: 'Presencia en Paraná',
    text: `${SITE.addressLine}. Atención cercana en el centro de la ciudad.`,
  },
  {
    title: 'Profesionalismo real',
    text: 'Transparencia, seriedad y seguimiento en venta y alquiler.',
  },
];
---

<BaseLayout title={`${SITE.name} | ${SITE.subtitle} en Paraná`}>
  <PropertyHeroSlider properties={heroSlides} />

  <section class="border-b border-brand-gray-200 bg-white py-6 md:py-7">
    <div class="section-shell">
      <div class="flex flex-col gap-3 text-center text-sm text-brand-gray-600 sm:flex-row sm:flex-wrap sm:items-center sm:justify-center sm:gap-x-10 sm:gap-y-2 md:justify-between md:text-left">
        <span>Venta · Alquiler · Tasación</span>
        <span>{SITE.addressLine}</span>
        <span>Atención personalizada en {SITE.city}</span>
      </div>
    </div>
  </section>

  <section class="section-shell py-14 md:py-16">
    <div class="grid gap-6 md:grid-cols-3 md:gap-7">
      {
        highlights.map((item) => (
          <article class="rounded-2xl bg-brand-gray-50 p-6">
            <div class="mb-3 h-px w-10 bg-brand-yellow"></div>
            <h2 class="font-display text-lg font-semibold text-brand-gray-900">{item.title}</h2>
            <p class="mt-2 text-sm leading-relaxed text-brand-gray-600">{item.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="bg-brand-gray-50 py-14 md:py-16">
    <div class="section-shell">
      <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="section-kicker">Selección destacada</p>
          <h2 class="section-title mt-2">Propiedades en {SITE.city}</h2>
        </div>
        <ButtonLink href="/propiedades" label="Ver catálogo completo" variant="secondary" />
      </div>
      <div class="grid grid-cols-1 items-start gap-6 sm:grid-cols-2 sm:gap-7 xl:grid-cols-3">
        {featuredGrid.map((property) => <PropertyCard property={property} />)}
      </div>
    </div>
  </section>

  <section class="section-shell py-14 md:py-16">
    <div class="card-premium flex flex-col gap-6 p-6 sm:p-8 md:flex-row md:items-center md:justify-between">
      <div class="max-w-xl">
        <p class="section-kicker">Vendedores y propietarios</p>
        <h2 class="font-display mt-2 text-2xl font-semibold text-brand-gray-900">¿Querés vender o alquilar?</h2>
        <p class="mt-3 text-brand-gray-600">
          Coordinamos publicación, consultas y visitas con un trato profesional en todo el proceso.
        </p>
      </div>
      <ButtonLink href="/contacto" label="Contactanos" />
    </div>
  </section>
</BaseLayout>
