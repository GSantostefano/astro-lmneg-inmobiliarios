---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, brandFull } from '../config/site';
import { getApiUrl, getBrowserApiUrl } from '../lib/api';
import { getWorkerEnv } from '../lib/cf-env';

export const prerender = false;

const apiUrl = getBrowserApiUrl();
const upstreamApiUrl = getApiUrl(getWorkerEnv());
---

<BaseLayout
  title={`Admin | ${SITE.name}`}
  description={`Acceso administrador de ${brandFull}.`}
>
  <section class="bg-brand-gray-900 px-5 py-12 text-white">
    <div class="mx-auto max-w-md">
      <h1 class="font-display text-3xl font-bold">Acceso admin</h1>
      <p class="mt-2 text-brand-gray-100">
        Ingresá con tu usuario para administrar propiedades y publicaciones.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-md px-5 py-12">
    <form id="email-login-form" class="space-y-4 rounded-2xl border border-brand-gray-200 bg-white p-6 shadow-sm">
      <label class="block text-sm font-medium text-brand-gray-700">
        Email
        <input
          name="email"
          type="email"
          required
          autocomplete="username"
          class="mt-1 w-full rounded-lg border border-brand-gray-200 px-3 py-2"
        />
      </label>
      <label class="block text-sm font-medium text-brand-gray-700">
        Contraseña
        <input
          name="password"
          type="password"
          required
          autocomplete="current-password"
          class="mt-1 w-full rounded-lg border border-brand-gray-200 px-3 py-2"
        />
      </label>
      <button
        type="submit"
        class="w-full rounded-lg bg-brand-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-brand-gray-700"
      >
        Ingresar
      </button>
    </form>

    <p id="login-message" class="mt-4 hidden rounded-lg p-3 text-sm" role="status"></p>

    <div
      id="login-config"
      class="hidden"
      data-api-url={apiUrl}
      data-upstream-api-url={upstreamApiUrl}
      aria-hidden="true"
    ></div>
  </div>
</BaseLayout>

<script>
  import { getSession, saveSession, getRedirectTarget } from '../lib/auth.ts';

  const cfg = document.getElementById('login-config')?.dataset ?? {};
  const apiUrl = cfg.apiUrl || 'http://localhost:3020';
  const upstreamApiUrl = cfg.upstreamApiUrl || apiUrl;

  const message = document.querySelector('#login-message');
  const emailForm = document.querySelector('#email-login-form');

  const session = getSession();
  if (session?.user.role === 'admin') {
    window.location.replace(getRedirectTarget('/mis-propiedades'));
  }

  function showMessage(text: string, type: 'error' | 'ok' = 'error') {
    if (!(message instanceof HTMLElement)) return;
    message.textContent = text;
    message.classList.remove('hidden', 'bg-red-50', 'text-red-800', 'bg-brand-yellow-soft', 'text-brand-gray-800');
    message.classList.add(
      type === 'ok' ? 'bg-brand-yellow-soft' : 'bg-red-50',
      type === 'ok' ? 'text-brand-gray-800' : 'text-red-800',
    );
  }

  async function finishLogin(token: string, user: unknown) {
    saveSession({ token, user } as Parameters<typeof saveSession>[0]);
    showMessage('Sesión iniciada. Redirigiendo…', 'ok');
    window.setTimeout(() => {
      window.location.href = getRedirectTarget('/mis-propiedades');
    }, 400);
  }

  emailForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!(emailForm instanceof HTMLFormElement)) return;
    const data = new FormData(emailForm);
    try {
      const res = await fetch(`${apiUrl}/api/users/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: data.get('email'),
          password: data.get('password'),
        }),
      });
      const json = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(json.message || `Error ${res.status}`);
      if (json.user?.role !== 'admin') {
        throw new Error('Esta cuenta no tiene permisos de administrador.');
      }
      await finishLogin(json.token, json.user);
    } catch (error) {
      const msg = error instanceof Error ? error.message : 'Login falló';
      const hint =
        msg.includes('Failed to fetch') || msg.includes('NetworkError')
          ? ` ¿Está el back en ${upstreamApiUrl}?`
          : '';
      showMessage(`${msg}${hint}`);
    }
  });
</script>
