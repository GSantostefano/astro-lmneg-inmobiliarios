---
import ListingImage from '../../components/ListingImage.astro';
import PropertyMap from '../../components/PropertyMap.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getApiUrl } from '../../lib/api';
import { getWorkerEnv } from '../../lib/cf-env';
import { loadPropertyBySlug } from '../../lib/catalog';
import {
  formatPrice,
  getPropertyGalleryImages,
  operationLabel,
  showsRoomMetrics,
  typeLabel,
} from '../../lib/properties';
import { buildPropertyWhatsAppLink } from '../../lib/whatsapp';
import { SITE } from '../../config/site';

export const prerender = false;

const apiUrl = getApiUrl(getWorkerEnv());
const { slug } = Astro.params;
const property = await loadPropertyBySlug(slug ?? '', apiUrl);

if (!property) {
  return Astro.redirect('/propiedades');
}

const galleryImages = getPropertyGalleryImages(property);
const galleryRest = galleryImages.slice(1);
const wspHref = buildPropertyWhatsAppLink(
  property.title,
  operationLabel(property.operation),
  property.refCode,
);
const showMetrics = showsRoomMetrics(property.type);
---

<BaseLayout title={`${property.title} | ${SITE.name}`} description={property.description} ogImage={property.heroImage}>
  <div class="section-shell py-8 md:py-10">
    <nav class="mb-8 text-sm text-brand-gray-500">
      <a href="/" class="no-underline hover:text-brand-gray-900">Inicio</a>
      <span class="mx-2">/</span>
      <a href="/propiedades" class="no-underline hover:text-brand-gray-900">Propiedades</a>
      <span class="mx-2">/</span>
      <span class="text-brand-gray-900">{property.title}</span>
    </nav>

    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px] lg:items-start">
      <div class="space-y-8">
        <section class="card-premium overflow-hidden">
          <ListingImage
            src={galleryImages[0]}
            alt={property.title}
            width={1400}
            height={780}
            loading="eager"
            class="aspect-[16/10] w-full object-cover"
          />
        </section>

        {
          galleryRest.length > 0 && (
            <section>
              <h2 class="font-display text-xl font-semibold text-brand-gray-900">
                Galería · {galleryRest.length} {galleryRest.length === 1 ? 'foto' : 'fotos'}
              </h2>
              <div class="mt-4 grid gap-3 sm:grid-cols-2">
                {galleryRest.map((image, index) => (
                  <ListingImage
                    src={image}
                    alt={`${property.title} - foto ${index + 2}`}
                    width={800}
                    height={500}
                    loading="lazy"
                    class="aspect-[4/3] w-full rounded-xl object-cover"
                  />
                ))}
              </div>
            </section>
          )
        }

        <section class="card-premium p-6 md:p-8">
          <p class="section-kicker">Descripción</p>
          <p class="mt-4 max-w-3xl leading-8 text-brand-gray-700">{property.description}</p>

          <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
            {
              showMetrics && property.rooms > 0 && (
                <div class="rounded-xl bg-brand-gray-50 p-4">
                  <p class="text-xs font-semibold uppercase tracking-wide text-brand-gray-500">Ambientes</p>
                  <p class="mt-1 text-lg font-semibold text-brand-gray-900">{property.rooms}</p>
                </div>
              )
            }
            {
              showMetrics && property.bathrooms > 0 && (
                <div class="rounded-xl bg-brand-gray-50 p-4">
                  <p class="text-xs font-semibold uppercase tracking-wide text-brand-gray-500">Baños</p>
                  <p class="mt-1 text-lg font-semibold text-brand-gray-900">{property.bathrooms}</p>
                </div>
              )
            }
            {
              property.coveredM2 > 0 && (
                <div class="rounded-xl bg-brand-gray-50 p-4">
                  <p class="text-xs font-semibold uppercase tracking-wide text-brand-gray-500">Cubiertos</p>
                  <p class="mt-1 text-lg font-semibold text-brand-gray-900">{property.coveredM2} m²</p>
                </div>
              )
            }
            {
              property.semiCoveredM2 > 0 && (
                <div class="rounded-xl bg-brand-gray-50 p-4">
                  <p class="text-xs font-semibold uppercase tracking-wide text-brand-gray-500">Semicubiertos</p>
                  <p class="mt-1 text-lg font-semibold text-brand-gray-900">{property.semiCoveredM2} m²</p>
                </div>
              )
            }
          </div>
        </section>

        {
          property.features.length > 0 && (
            <section class="card-premium p-6 md:p-8">
              <h2 class="font-display text-xl font-semibold text-brand-gray-900">Características</h2>
              <ul class="mt-4 grid gap-2 sm:grid-cols-2">
                {property.features.map((feature) => (
                  <li class="flex items-start gap-2 text-sm text-brand-gray-700">
                    <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-yellow" aria-hidden="true"></span>
                    {feature}
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        <section class="card-premium p-6 md:p-8">
          <PropertyMap
            neighborhood={property.neighborhood}
            city={property.city}
            address={property.address}
            mapUrl={property.mapUrl}
            latitude={property.latitude}
            longitude={property.longitude}
          />
        </section>
      </div>

      <aside class="lg:sticky lg:top-24">
        <div class="card-premium p-6 md:p-7">
          <div class="flex flex-wrap items-center gap-2">
            <span class="rounded-full bg-brand-yellow/90 px-3 py-1 text-[11px] font-semibold uppercase tracking-wide text-brand-gray-900">
              {operationLabel(property.operation)}
            </span>
            <span class="text-xs font-medium uppercase tracking-wide text-brand-gray-500">{typeLabel(property.type)}</span>
          </div>

          <h1 class="font-display mt-4 text-2xl font-semibold leading-snug text-brand-gray-900">{property.title}</h1>
          <p class="mt-2 text-sm text-brand-gray-600">{property.neighborhood}, {property.city}</p>
          <p class="mt-1 text-xs text-brand-gray-400">Ref. {property.refCode}</p>

          <p class="mt-6 font-display text-3xl font-semibold text-brand-gray-900">
            {formatPrice(property.price, property.currency)}
          </p>
          <p class="mt-1 text-xs uppercase tracking-wide text-brand-gray-500">{property.status}</p>

          <div class="mt-8 space-y-3">
            <a
              href={wspHref}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex w-full items-center justify-center rounded-xl bg-brand-yellow px-5 py-3 text-sm font-bold text-brand-gray-900 no-underline transition hover:bg-brand-yellow-dark"
            >
              Consultar por WhatsApp
            </a>
            <a
              href={`/contacto?property=${property.slug}&title=${encodeURIComponent(property.title)}`}
              class="inline-flex w-full items-center justify-center rounded-xl border border-brand-gray-200 bg-brand-gray-50 px-5 py-3 text-sm font-semibold text-brand-gray-900 no-underline transition hover:bg-white"
            >
              Formulario de contacto
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
