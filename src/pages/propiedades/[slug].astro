---
import ListingImage from '../../components/ListingImage.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { properties } from '../../data/properties';
import {
  formatPrice,
  getPropertyBySlug,
  getPropertyGalleryImages,
  operationLabel,
  showsRoomMetrics,
  typeLabel,
} from '../../lib/properties';
import { buildPropertyWhatsAppLink } from '../../lib/whatsapp';
import { SITE } from '../../config/site';

export function getStaticPaths() {
  return properties.map((property) => ({
    params: { slug: property.slug },
  }));
}

const { slug } = Astro.params;
const property = getPropertyBySlug(slug ?? '');

if (!property) {
  return Astro.redirect('/propiedades');
}

const galleryImages = getPropertyGalleryImages(property);
const galleryRest = galleryImages.slice(1);
const wspHref = buildPropertyWhatsAppLink(
  property.title,
  operationLabel(property.operation),
  property.refCode,
);
const showMetrics = showsRoomMetrics(property.type);
---

<BaseLayout title={`${property.title} | ${SITE.name}`} description={property.description} ogImage={property.heroImage}>
  <div class="mx-auto max-w-6xl px-5 py-8">
    <nav class="mb-6 text-sm text-brand-gray-500">
      <a href="/" class="no-underline hover:text-brand-gray-900">Inicio</a> /
      <a href="/propiedades" class="no-underline hover:text-brand-gray-900"> Propiedades</a> /
      <span class="text-brand-gray-900">{property.title}</span>
    </nav>

    <section class="overflow-hidden rounded-2xl border border-brand-gray-200 bg-white shadow-sm">
      <ListingImage
        src={galleryImages[0]}
        alt={property.title}
        width={1400}
        height={780}
        loading="eager"
        class="h-80 w-full object-cover"
      />
      <div class="p-6 md:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <span class="rounded-full bg-brand-yellow px-3 py-1 text-xs font-semibold uppercase text-brand-gray-900">
            {operationLabel(property.operation)}
          </span>
          <span class="text-sm text-brand-gray-500">{typeLabel(property.type)} · {property.status}</span>
        </div>
        <h1 class="font-display mt-3 text-3xl font-bold text-brand-gray-900">{property.title}</h1>
        <p class="mt-2 text-brand-gray-600">{property.neighborhood}, {property.city}</p>
        <p class="mt-1 text-sm font-medium text-brand-gray-500">Referencia: {property.refCode}</p>
        <p class="mt-4 text-3xl font-bold text-brand-gray-900">{formatPrice(property.price, property.currency)}</p>
        <p class="mt-4 max-w-3xl leading-7 text-brand-gray-700">{property.description}</p>

        <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {
            showMetrics && property.rooms > 0 && (
              <div class="rounded-xl bg-brand-gray-50 p-4 text-sm">
                <p class="font-semibold text-brand-gray-900">Ambientes</p>
                <p class="text-brand-gray-600">{property.rooms}</p>
              </div>
            )
          }
          {
            showMetrics && property.bathrooms > 0 && (
              <div class="rounded-xl bg-brand-gray-50 p-4 text-sm">
                <p class="font-semibold text-brand-gray-900">Baños</p>
                <p class="text-brand-gray-600">{property.bathrooms}</p>
              </div>
            )
          }
          {
            property.coveredM2 > 0 && (
              <div class="rounded-xl bg-brand-gray-50 p-4 text-sm">
                <p class="font-semibold text-brand-gray-900">Cubiertos</p>
                <p class="text-brand-gray-600">{property.coveredM2} m²</p>
              </div>
            )
          }
          {
            property.semiCoveredM2 > 0 && (
              <div class="rounded-xl bg-brand-gray-50 p-4 text-sm">
                <p class="font-semibold text-brand-gray-900">Semicubiertos</p>
                <p class="text-brand-gray-600">{property.semiCoveredM2} m²</p>
              </div>
            )
          }
        </div>

        {
          galleryRest.length > 0 && (
            <div class="mt-8">
              <h2 class="font-display text-xl font-bold text-brand-gray-900">
                Galería ({galleryRest.length} {galleryRest.length === 1 ? 'foto más' : 'fotos más'})
              </h2>
              <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
                {galleryRest.map((image, index) => (
                  <ListingImage
                    src={image}
                    alt={`${property.title} - foto ${index + 2}`}
                    width={800}
                    height={500}
                    loading="lazy"
                    class="h-40 w-full rounded-xl object-cover"
                  />
                ))}
              </div>
            </div>
          )
        }

        <div class="mt-8">
          <h2 class="font-display text-xl font-bold text-brand-gray-900">Características</h2>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-brand-gray-700">
            {property.features.map((feature) => (
              <li>{feature}</li>
            ))}
          </ul>
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={wspHref}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex rounded-lg bg-brand-yellow px-5 py-2.5 text-sm font-bold text-brand-gray-900 no-underline hover:bg-brand-yellow-dark"
          >
            Consultar por WhatsApp
          </a>
          <a
            href={`/contacto?property=${property.slug}&title=${encodeURIComponent(property.title)}`}
            class="inline-flex rounded-lg border border-brand-gray-200 bg-brand-gray-50 px-5 py-2.5 text-sm font-semibold text-brand-gray-900 no-underline hover:bg-brand-yellow-soft"
          >
            Formulario de contacto
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
