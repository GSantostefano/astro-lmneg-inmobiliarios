---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';

const faqs = [
  {
    q: '¿En qué zonas de Paraná operan?',
    a: 'Trabajamos en toda la ciudad de Paraná y alrededores: Centro, Parque Urquiza, Microcentro, Barrio Norte, Villa Urquiza, Semillero y otros barrios según disponibilidad.',
  },
  {
    q: '¿Puedo alquilar o comprar con garantía?',
    a: 'Sí. En alquileres solicitamos garantías según el propietario (propietaria, seguro de caución, etc.). En compras te asesoramos sobre documentación y pasos previos a la escritura.',
  },
  {
    q: '¿Cómo coordino una visita?',
    a: 'Contactanos por WhatsApp o el formulario de contacto. Agendamos día y horario según disponibilidad de la propiedad y del interesado.',
  },
  {
    q: '¿Publican propiedades de terceros?',
    a: 'Sí. Si querés vender o alquilar tu departamento o casa en Paraná, evaluamos la publicación y te acompañamos en la comercialización.',
  },
  {
    q: '¿Los precios están en pesos o dólares?',
    a: 'Cada propiedad indica su moneda (ARS o USD). Los valores pueden actualizarse; confirmá el monto vigente al consultar.',
  },
];
---

<BaseLayout title={`Preguntas frecuentes | ${SITE.name}`}>
  <section class="bg-brand-yellow-soft px-5 py-12">
    <div class="mx-auto max-w-3xl">
      <h1 class="font-display text-3xl font-bold text-brand-gray-900">Preguntas frecuentes</h1>
      <p class="mt-2 text-brand-gray-600">Respuestas sobre compra, alquiler y publicación de propiedades en Paraná.</p>
    </div>
  </section>

  <div class="mx-auto max-w-3xl px-5 py-10">
    <div class="space-y-3">
      {
        faqs.map((item) => (
          <details class="rounded-xl border border-brand-gray-200 bg-white p-5 shadow-sm">
            <summary class="cursor-pointer font-semibold text-brand-gray-900">{item.q}</summary>
            <p class="mt-3 text-sm leading-relaxed text-brand-gray-600">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</BaseLayout>
