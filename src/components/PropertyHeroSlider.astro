---
import ButtonLink from './ui/ButtonLink.astro';
import type { Property } from '../data/properties';
import { SITE } from '../config/site';
import { getHeroSlideImage } from '../lib/hero-images';
import { formatPrice, formatPropertyMeta, operationLabel, typeLabel } from '../lib/properties';

interface Props {
  properties: Property[];
}

const { properties } = Astro.props;

if (properties.length === 0) {
  return null;
}
---

<section
  class="property-hero-slider relative overflow-hidden bg-brand-gray-900 text-white"
  data-hero-slider
  aria-roledescription="carousel"
  aria-label="Propiedades destacadas"
>
  <div class="pointer-events-none absolute inset-x-0 top-0 z-20">
    <div class="section-shell pt-10 md:pt-12">
      <p class="section-kicker text-brand-yellow/90">{SITE.city} · {SITE.province}</p>
      <h1 class="font-display mt-3 text-3xl font-semibold leading-tight md:text-4xl lg:text-5xl">
        Tu próximo hogar en Paraná
      </h1>
      <p class="mt-3 max-w-2xl font-display text-lg text-brand-yellow md:text-xl">
        {SITE.slogan}
      </p>
    </div>
  </div>

  <div class="relative min-h-[32rem] md:min-h-[36rem]">
    {
      properties.map((property, index) => {
        const slideImage = getHeroSlideImage(property);
        return (
        <article
          class:list={['hero-slide', index === 0 && 'is-active']}
          data-slide
          aria-hidden={index !== 0}
          aria-roledescription="slide"
          aria-label={`${index + 1} de ${properties.length}`}
        >
          <div
            class="hero-slide__media absolute inset-0 overflow-hidden"
            style={`--ken-pan-x: ${index % 2 === 0 ? '1.5%' : '-1.5%'}; --ken-pan-y: ${index % 3 === 0 ? '1%' : '-1%'}`}
            aria-hidden="true"
          >
            <div class="hero-slide__ken-burns">
              <img
                src={slideImage}
                alt=""
                width={1920}
                height={1280}
                loading={index === 0 ? 'eager' : 'lazy'}
                decoding="async"
                fetchpriority={index === 0 ? 'high' : 'auto'}
                class="hero-slide__photo"
              />
            </div>
            <div class="absolute inset-0 bg-gradient-to-r from-brand-gray-900/75 via-brand-gray-900/35 to-brand-gray-900/10" />
          </div>

          <div class="section-shell relative flex min-h-[32rem] flex-col justify-end pb-14 pt-44 md:min-h-[36rem] md:pb-16 md:pt-48">
            <div class="hero-slide__caption max-w-2xl">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-yellow/90">
                {operationLabel(property.operation)} · {typeLabel(property.type)}
              </p>
              <h2 class="font-display mt-2 text-2xl font-semibold leading-tight md:text-3xl lg:text-4xl">
                {property.title}
              </h2>
              <p class="mt-2 text-sm text-brand-gray-100 md:text-base">
                {formatPropertyMeta(property)}
              </p>
              <p class="mt-4 text-2xl font-bold text-brand-yellow md:text-3xl">
                {formatPrice(property.price, property.currency)}
              </p>
              <div class="mt-8 flex flex-wrap gap-3">
                <ButtonLink href={`/propiedades/${property.slug}`} label="Ver propiedad" />
                <ButtonLink href="/propiedades" label="Ver catálogo" variant="ghost" />
              </div>
            </div>
          </div>
        </article>
        );
      })
    }
  </div>

  {
    properties.length > 1 && (
      <>
        <div class="pointer-events-none absolute inset-x-0 top-1/2 z-10 hidden -translate-y-1/2 md:block">
          <div class="section-shell flex justify-between">
            <button
              type="button"
              class="pointer-events-auto inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/25 bg-brand-gray-900/50 text-white backdrop-blur transition hover:bg-brand-gray-900/80"
              data-prev
              aria-label="Propiedad anterior"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
            </button>
            <button
              type="button"
              class="pointer-events-auto inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/25 bg-brand-gray-900/50 text-white backdrop-blur transition hover:bg-brand-gray-900/80"
              data-next
              aria-label="Propiedad siguiente"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </div>
        </div>

        <div class="absolute bottom-6 left-0 right-0 z-10 flex justify-center gap-2" role="tablist" aria-label="Seleccionar propiedad">
          {
            properties.map((property, index) => (
              <button
                type="button"
                class:list={['hero-dot', index === 0 && 'is-active']}
                data-dot
                data-index={index}
                role="tab"
                aria-selected={index === 0}
                aria-label={`Ir a ${property.title}`}
              />
            ))
          }
        </div>
      </>
    )
  }
</section>

<style>
  @reference "../styles/global.css";

  .hero-slide {
    @apply absolute inset-0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 500ms linear;
    z-index: 0;
  }

  .hero-slide.is-active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    z-index: 1;
  }

  .hero-slide__media {
    transform: translateZ(0);
  }

  .hero-slide__ken-burns {
    position: absolute;
    inset: -3%;
    width: 106%;
    height: 106%;
    transform: scale(1) translate3d(0, 0, 0);
    transform-origin: center center;
    will-change: transform;
  }

  .hero-slide__photo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-slide.is-active .hero-slide__ken-burns {
    animation: hero-ken-burns-pulse var(--hero-slide-ms, 9000ms) ease-in-out infinite;
  }

  @keyframes hero-ken-burns-pulse {
    0%,
    100% {
      transform: scale(1) translate3d(0, 0, 0);
    }
    50% {
      transform: scale(1.05) translate3d(var(--ken-pan-x, 1.5%), var(--ken-pan-y, 1%), 0);
    }
  }

  .hero-slide__caption {
    opacity: 0;
    transform: translate3d(0, 1.25rem, 0);
    transition:
      opacity 500ms linear,
      transform 500ms linear;
  }

  .hero-slide.is-active .hero-slide__caption {
    opacity: 1;
    transform: translate3d(0, 0, 0);
    transition-delay: 120ms;
  }

  .hero-dot {
    @apply h-2 w-2 rounded-full bg-white/35 transition;
  }

  .hero-dot.is-active {
    @apply w-6 bg-brand-yellow;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-slide,
    .hero-slide__caption {
      transition: none;
    }

    .hero-slide.is-active .hero-slide__ken-burns {
      animation: none;
      transform: scale(1) translate3d(0, 0, 0);
    }
  }
</style>

<script>
  function initHeroSlider(root: HTMLElement) {
    const slides = [...root.querySelectorAll<HTMLElement>('[data-slide]')];
    const dots = [...root.querySelectorAll<HTMLButtonElement>('[data-dot]')];
    if (slides.length <= 1) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval> | undefined;
    const intervalMs = 9000;
    root.style.setProperty('--hero-slide-ms', `${intervalMs}ms`);
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function restartKenBurns(slide: HTMLElement | undefined) {
      const layer = slide?.querySelector<HTMLElement>('.hero-slide__ken-burns');
      if (!layer) return;
      layer.style.animation = 'none';
      layer.style.transform = 'scale(1) translate3d(0, 0, 0)';
      void layer.offsetWidth;
      layer.style.removeProperty('animation');
      layer.style.removeProperty('transform');
    }

    function setActive(index: number) {
      const leaving = slides[current];
      leaving?.classList.remove('is-active');
      leaving?.setAttribute('aria-hidden', 'true');
      dots[current]?.classList.remove('is-active');
      dots[current]?.setAttribute('aria-selected', 'false');

      current = (index + slides.length) % slides.length;

      const entering = slides[current];
      entering?.classList.add('is-active');
      entering?.setAttribute('aria-hidden', 'false');
      dots[current]?.classList.add('is-active');
      dots[current]?.setAttribute('aria-selected', 'true');
      restartKenBurns(entering);
    }

    function next() {
      setActive(current + 1);
    }

    function prev() {
      setActive(current - 1);
    }

    function stopAutoplay() {
      if (timer) clearInterval(timer);
      timer = undefined;
    }

    function startAutoplay() {
      if (reducedMotion) return;
      stopAutoplay();
      timer = setInterval(next, intervalMs);
    }

    root.querySelector('[data-next]')?.addEventListener('click', () => {
      next();
      startAutoplay();
    });

    root.querySelector('[data-prev]')?.addEventListener('click', () => {
      prev();
      startAutoplay();
    });

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        setActive(index);
        startAutoplay();
      });
    });

    root.addEventListener('mouseenter', stopAutoplay);
    root.addEventListener('mouseleave', startAutoplay);
    root.addEventListener('focusin', stopAutoplay);
    root.addEventListener('focusout', startAutoplay);

    startAutoplay();
    restartKenBurns(slides[0]);
  }

  document.querySelectorAll<HTMLElement>('[data-hero-slider]').forEach(initHeroSlider);
</script>
