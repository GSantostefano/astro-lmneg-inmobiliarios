---
import { SITE, brandFull } from '../config/site';
import { buildWhatsAppLink } from '../lib/whatsapp';
import BrandLogo from './BrandLogo.astro';
import SocialLinks from './SocialLinks.astro';

const wspLink = buildWhatsAppLink(
  `Hola ${brandFull}, quiero consultar por una propiedad en ${SITE.city}.`,
);
---

<footer class="mt-16 border-t border-brand-gray-200 bg-brand-gray-50">
  <div class="mx-auto max-w-6xl px-5 py-10">
    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <BrandLogo size="md" />
        <p class="mt-2 text-sm text-brand-gray-500">{SITE.tagline}</p>
      </div>
      <div>
        <p class="text-sm font-semibold text-brand-gray-900">Enlaces</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/propiedades" class="text-brand-gray-600 no-underline hover:text-brand-gray-900">Propiedades</a></li>
          <li><a href="/tasacion" class="text-brand-gray-600 no-underline hover:text-brand-gray-900">Tasación</a></li>
          <li><a href="/nosotros" class="text-brand-gray-600 no-underline hover:text-brand-gray-900">Nosotros</a></li>
          <li><a href="/contacto" class="text-brand-gray-600 no-underline hover:text-brand-gray-900">Contacto</a></li>
        </ul>
      </div>
      <div>
        <p class="text-sm font-semibold text-brand-gray-900">Contacto</p>
        <p class="mt-3 text-sm text-brand-gray-600">{SITE.address}</p>
        <p class="mt-1 text-sm text-brand-gray-600">
          <a href={`tel:+54${SITE.phone}`} class="text-brand-gray-900 no-underline hover:underline">
            {SITE.phoneDisplay}
          </a>
        </p>
        <a
          href={wspLink}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 inline-block text-sm font-semibold text-brand-gray-900 no-underline hover:underline"
        >
          WhatsApp
        </a>
        <p class="mt-4 text-sm font-semibold text-brand-gray-900">Redes</p>
        <SocialLinks class="mt-2" />
      </div>
    </div>
    <p class="mt-8 border-t border-brand-gray-200 pt-6 text-center text-xs text-brand-gray-500">
      © {new Date().getFullYear()} {brandFull}. Todos los derechos reservados.
    </p>
    <p class="mt-3 text-center text-[11px] leading-relaxed text-brand-gray-400">
      {SITE.legalDisclaimer}
    </p>
  </div>
</footer>