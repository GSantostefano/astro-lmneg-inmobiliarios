---
import { SITE } from '../config/site';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
const linkClass =
  'text-brand-gray-600 no-underline hover:text-brand-gray-900 underline-offset-2 hover:underline';
---

<div class:list={['flex flex-wrap gap-x-4 gap-y-1 text-sm', className]}>
  <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class={linkClass}>
    Instagram
  </a>
  <a href={SITE.facebookUrl} target="_blank" rel="noopener noreferrer" class={linkClass}>
    Facebook
  </a>
</div>
