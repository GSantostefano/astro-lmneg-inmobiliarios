---
import { SITE } from '../config/site';
import BrandLogo from './BrandLogo.astro';

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/propiedades', label: 'Propiedades' },
  { href: '/tasacion', label: 'Tasación' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/faq', label: 'FAQ' },
  { href: '/contacto', label: 'Contacto' },
];
---

<div class="border-b border-brand-gray-200 bg-brand-yellow-soft">
  <div class="mx-auto max-w-6xl px-8 py-2 text-center text-xs text-brand-gray-700 sm:px-10 md:px-12 lg:px-14 md:text-left">
    <span class="font-medium">{SITE.city}, {SITE.province}</span>
    <span class="mx-2 hidden text-brand-gray-200 md:inline">|</span>
    <span class="hidden md:inline">{SITE.addressLine} · {SITE.phoneDisplay}</span>
  </div>
</div>

<header class="sticky top-0 z-30 border-b border-brand-gray-200/80 bg-white/90 shadow-[0_1px_0_rgba(26,24,22,0.04)] backdrop-blur-md">
  <div class="mx-auto max-w-6xl px-8 py-4 sm:px-10 md:px-12 lg:px-14">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <BrandLogo />

      <nav
        aria-label="Navegación principal"
        class="flex w-full flex-col gap-4 lg:ml-auto lg:w-auto lg:flex-row lg:items-center lg:gap-8"
      >
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm font-medium">
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                class="text-brand-gray-700 no-underline transition hover:text-brand-gray-900"
              >
                {link.label}
              </a>
            ))
          }
        </div>

        <div
          id="auth-user"
          class="hidden flex-col gap-3 border-t border-brand-gray-100 pt-4 sm:flex-row sm:items-center lg:ml-auto lg:border-t-0 lg:border-l lg:border-brand-gray-200 lg:pl-6 lg:pt-0"
        >
          <div
            id="auth-user-badge"
            class="flex min-w-0 items-center gap-2.5 rounded-full bg-brand-gray-50 px-3 py-1.5 ring-1 ring-brand-gray-200"
          >
            <span
              id="auth-user-initial"
              class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-yellow text-xs font-bold text-brand-gray-900"
              aria-hidden="true"
            ></span>
            <span id="auth-user-name" class="max-w-[9rem] truncate text-sm font-semibold text-brand-gray-900 sm:max-w-[11rem]"></span>
          </div>

          <div class="flex flex-wrap items-center gap-2 sm:gap-3">
            <a
              href="/mis-propiedades"
              class="rounded-lg px-3 py-2 text-sm font-medium text-brand-gray-700 no-underline transition hover:bg-brand-gray-50 hover:text-brand-gray-900"
            >
              Mis propiedades
            </a>
            <a
              id="auth-admin-publicar"
              href="/publicar"
              class="hidden inline-flex rounded-lg bg-brand-yellow px-4 py-2 text-sm font-semibold text-brand-gray-900 no-underline hover:bg-brand-yellow-dark"
            >
              Publicar
            </a>
            <button
              id="auth-logout"
              type="button"
              class="rounded-lg border border-brand-gray-200 bg-white px-4 py-2 text-sm font-medium text-brand-gray-700 transition hover:border-brand-gray-300 hover:bg-brand-gray-50"
            >
              Salir
            </button>
          </div>
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  import { clearSession, getSession } from '../lib/auth.ts';

  const user = document.querySelector('#auth-user');
  const userName = document.querySelector('#auth-user-name');
  const userInitial = document.querySelector('#auth-user-initial');
  const logoutBtn = document.querySelector('#auth-logout');
  const adminPublicar = document.querySelector('#auth-admin-publicar');

  function initialsFromName(name: string) {
    const parts = name.trim().split(/\s+/).filter(Boolean);
    if (parts.length === 0) return '?';
    if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
    return `${parts[0][0]}${parts[1][0]}`.toUpperCase();
  }

  function renderAuth() {
    const session = getSession();
    const loggedIn = Boolean(session);
    user?.classList.toggle('hidden', !loggedIn);
    if (loggedIn && session) {
      if (userName) userName.textContent = session.user.name;
      if (userInitial) userInitial.textContent = initialsFromName(session.user.name);
      adminPublicar?.classList.toggle('hidden', session.user.role !== 'admin');
    } else {
      adminPublicar?.classList.add('hidden');
    }
  }

  renderAuth();
  window.addEventListener('lmneg-auth-change', renderAuth);
  logoutBtn?.addEventListener('click', () => {
    clearSession();
    window.location.href = '/';
  });
</script>
