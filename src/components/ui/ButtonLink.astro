---
interface Props {
  href: string;
  label: string;
  variant?: 'primary' | 'secondary';
}

const { href, label, variant = 'primary' } = Astro.props;

const classes =
  variant === 'primary'
    ? 'bg-brand-yellow text-brand-gray-900 hover:bg-brand-yellow-dark'
    : 'border border-brand-gray-300 bg-white text-brand-gray-900 hover:bg-brand-gray-50';
---

<a
  href={href}
  class:list={[
    'inline-flex items-center rounded-lg px-5 py-2.5 text-sm font-semibold no-underline transition',
    classes,
  ]}
>
  {label}
</a>
