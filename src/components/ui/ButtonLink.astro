---
interface Props {
  href: string;
  label: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  external?: boolean;
}

const { href, label, variant = 'primary', external = false } = Astro.props;

const classes =
  variant === 'primary'
    ? 'bg-brand-yellow text-brand-gray-900 hover:bg-brand-yellow-dark shadow-sm'
    : variant === 'ghost'
      ? 'border border-white/30 bg-white/10 text-white backdrop-blur hover:bg-white/20'
      : 'border border-brand-gray-200 bg-white text-brand-gray-900 hover:border-brand-gray-300 hover:bg-brand-gray-50';
---

<a
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class:list={[
    'inline-flex items-center rounded-xl px-6 py-3 text-sm font-semibold tracking-wide no-underline transition duration-200',
    classes,
  ]}
>
  {label}
</a>
