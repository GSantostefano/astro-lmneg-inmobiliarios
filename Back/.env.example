# Backend
BACK_PORT=3020
NODE_ENV=development
DEBUG_ROUTES=0

# ----------------------------
# MySQL (Workbench)
# En esta máquina a veces: puerto 3307, password admin123
# ----------------------------
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3307
DB_NAME=lmneg_inmobiliarios
DB_USER=root
DB_PASSWORD=admin123
DB_LOG=0
DB_SYNC=1

# ----------------------------
# SQLite (alternativa local)
# ----------------------------
# DB_DIALECT=sqlite
# DB_PATH=./database.sqlite

# JWT
JWT_SECRET=change_me_lmneg_jwt_secret
JWT_EXPIRES_IN=7d

# Google OAuth (mismo Client ID que el front)
GOOGLE_CLIENT_ID=

# CORS — orígenes del front Astro (local + dominio CF + custom)
CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321,https://lmneginmobiliarios.com.ar,https://astro-lmneg-inmobiliarios.gabrielsantostefano.workers.dev

# URL pública del API (para URLs absolutas de /uploads/...)
# Ej: https://xxxx.trycloudflare.com (túnel cloudflared → localhost:3020)
PUBLIC_BASE_URL=

# Rate limit
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=240
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=30
